[node name="NoteTitle" type="Label" parent="Center/Panel/VBox/Notifications"]
text = "通知样式（信息 / 警告 / 成功）"

[node name="NoteRow" type="HBoxContainer" parent="Center/Panel/VBox/Notifications"]
