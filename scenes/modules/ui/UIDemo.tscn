selected = 1
popup/item_0/text = "低"
popup/item_1/text = "中"
popup/item_2/text = "高"

[node name="Disabled" type="Button" parent="Center/Panel/VBox/Examples/Row2"]
text = "不可用按钮"
disabled = true

[node name="ButtonRow" type="HBoxContainer" parent="Center/Panel/VBox"]
alignment = 1

[node name="Primary" type="Button" parent="Center/Panel/VBox/ButtonRow"]
text = "确认"

[node name="Secondary" type="Button" parent="Center/Panel/VBox/ButtonRow"]
text = "取消"

[node name="Notifications" type="VBoxContainer" parent="Center/Panel/VBox"]
