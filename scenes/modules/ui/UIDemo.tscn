[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/modules/ModuleDemoBase.gd" id="1"]

[node name="UIDemo" type="Control"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1")
demo_name = "界面模块"
auto_quit_seconds = 0.0

[node name="Center" type="CenterContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Panel" type="PanelContainer" parent="Center"]
custom_minimum_size = Vector2(760, 360)

[node name="VBox" type="VBoxContainer" parent="Center/Panel"]
theme_override_constants/separation = 14

[node name="Title" type="Label" parent="Center/Panel/VBox"]
text = "界面模块：主题、布局与状态"
horizontal_alignment = 1

[node name="Desc" type="Label" parent="Center/Panel/VBox"]
text = "这里是独立运行的界面演示，用于验证主题、控件样式与中文文案。"
autowrap_mode = 3

[node name="Examples" type="VBoxContainer" parent="Center/Panel/VBox"]
theme_override_constants/separation = 10

[node name="Row1" type="HBoxContainer" parent="Center/Panel/VBox/Examples"]
theme_override_constants/separation = 10

[node name="Check" type="CheckBox" parent="Center/Panel/VBox/Examples/Row1"]
