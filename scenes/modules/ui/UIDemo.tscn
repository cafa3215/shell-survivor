value = 70.0

[node name="Row2" type="HBoxContainer" parent="Center/Panel/VBox/Examples"]
theme_override_constants/separation = 10

[node name="OptionLabel" type="Label" parent="Center/Panel/VBox/Examples/Row2"]
text = "画质"

[node name="Quality" type="OptionButton" parent="Center/Panel/VBox/Examples/Row2"]
