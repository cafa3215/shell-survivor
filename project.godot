; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Shell Survivor"
run/main_scene="res://scenes/Main_new.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://scripts/autoload/EventBus.gd"
GameDB="*res://scripts/autoload/GameDB.gd"
AudioManager="*res://scripts/autoload/AudioManager.gd"
Settings="*res://scripts/autoload/Settings.gd"
RunStats="*res://scripts/autoload/RunStats.gd"
CombatFeedback="*res://scripts/autoload/CombatFeedback.gd"
MetaProgress="*res://scripts/autoload/MetaProgress.gd"
ActiveSkillManager="*res://scripts/autoload/ActiveSkillManager.gd"
SentryBridge="*res://scripts/autoload/SentryBridge.gd"
AnalyticsBridge="*res://scripts/autoload/AnalyticsBridge.gd"
InputManager="*res://scripts/autoload/InputManager.gd"

[display]

window/stretch/mode="viewport"
window/stretch/aspect="keep_height"
window/handheld/orientation="sensor_landscape"
window/size/window_width=1920
window/size/window_height=1080

[gdscript]

warnings/enable=true

[gui]

theme/custom="res://assets/themes/cyber_theme.tres"

